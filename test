/* 渲染 POI 卡片 */
function renderPOIs(filter='all'){
  const grid = document.getElementById('poiGrid');
  grid.innerHTML = '';
  const filtered = filter==='all' ? POIS : POIS.filter(p=>p.risk===filter);
  filtered.forEach((poi,i)=>{
    const pct = Math.round(poi.density*100);
    const riskLabel = poi.risk === 'very_high' ? '极高风险' : (poi.risk === 'high' ? '高风险' : (poi.risk === 'medium' ? '中风险' : '低风险'));
    const card = document.createElement('div');
    card.className = `poi-card ${poi.risk}`;
    card.style.animationDelay = `${i*.05}s`;
    card.innerHTML = `
      <div class="poi-card-top">
        <div class="poi-name">${poi.name}</div>
        <div class="risk-badge ${poi.risk}">${riskLabel}</div>
      </div>
      <div class="poi-category">${poi.cat}</div>
      <div class="density-bar-wrap">
        <div class="density-label">
          <span>GPS 密度</span>
          <span>${poi.density.toFixed(2)}</span>
        </div>
        <div class="density-bar">
          <div class="density-fill" style="width:0%" data-width="${pct}%"></div>
        </div>
      </div>
      <div class="poi-meta">
        <span>${IC.clock} ${poi.dwell} 分钟</span>
        <span>${IC.mapPin} ${poi.tracks} 条轨迹</span>
      </div>`;
    grid.appendChild(card);
    setTimeout(()=>{
      const fill = card.querySelector('.density-fill');
      if(fill) fill.style.width = fill.dataset.width;
    }, 100 + i*40);
  });
}

