/* ── LEAFLET MAP 初始化 ── */
let map;
let markersList = [];

function initInteractiveMap() {
  map = L.map('poi-map').setView([18.7883, 98.9853], 13);
  
  L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
    attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OSM</a> & CartoDB',
    subdomains: 'abcd',
    maxZoom: 19,
    minZoom: 10
  }).addTo(map);
  
  function getColorByDensity(density) {
    if (density >= 0.8) return '#e03939';
    if (density >= 0.6) return '#c8972a';
    return '#2d6a4f';
  }
  
  POIS.forEach((poi, idx) => {
    const color = getColorByDensity(poi.density);
    const radius = 8 + Math.floor(poi.density * 8);
    
    const circleMarker = L.circleMarker([poi.lat, poi.lng], {
      radius: radius,
      fillColor: color,
      color: '#fff',
      weight: 2,
      opacity: 1,
      fillOpacity: 0.85
    });
    
    const popupContent = `
      <div class="poi-popup">
        <div class="poi-popup-name">${poi.name}</div>
        <div class="poi-popup-en">${poi.cat}</div>
        <div class="poi-popup-grid">
          <div class="poi-popup-stat">
            <div class="poi-popup-val" style="color:${color}">${Math.round(poi.density*100)}%</div>
            <div class="poi-popup-lbl">GPS 密度</div>
          </div>
          <div class="poi-popup-stat">
            <div class="poi-popup-val">${poi.dwell} 分钟</div>
            <div class="poi-popup-lbl">平均停留</div>
          </div>
          <div class="poi-popup-stat">
            <div class="poi-popup-val">${poi.sentiment || '—'}%</div>
            <div class="poi-popup-lbl">正面评价</div>
          </div>
          <div class="poi-popup-stat">
            <div class="poi-popup-val">${poi.time || '—'}</div>
            <div class="poi-popup-lbl">高峰时段</div>
          </div>
        </div>
      </div>
    `;
    
    circleMarker.bindPopup(popupContent);
    circleMarker.addTo(map);
    markersList.push({ marker: circleMarker, idx: idx, data: poi });
    
    circleMarker.on('click', () => {
      showPOIPreview(idx);
    });
    
    if (poi.density >= 0.8) {
      L.circleMarker([poi.lat, poi.lng], {
        radius: radius + 5,
        fillColor: 'transparent',
        color: color,
        weight: 1.5,
        opacity: 0.4,
        fillOpacity: 0,
        interactive: false
      }).addTo(map);
    }
  });
  
  const poiRows = document.querySelectorAll('.map-poi-row');
  poiRows.forEach((row, idx) => {
    row.addEventListener('click', () => {
      const poiIdx = parseInt(row.getAttribute('data-poi-idx'), 10);
      if (!isNaN(poiIdx) && markersList[poiIdx]) {
        const targetMarker = markersList[poiIdx];
        map.flyTo([targetMarker.data.lat, targetMarker.data.lng], 15, { duration: 1.2 });
        setTimeout(() => targetMarker.marker.openPopup(), 1300);
        poiRows.forEach(r => r.style.background = '');
        row.style.background = 'rgba(200,151,42,.15)';
        showPOIPreview(poiIdx);
      }
    });
  });
}

