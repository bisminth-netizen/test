async function runDemo(query,btn){
  if(chatRunning) return;
  chatRunning = true;
  document.querySelectorAll('.query-chip').forEach(b=>b.classList.remove('selected'));
  btn.classList.add('selected');
  const body = document.getElementById('chatBody');
  body.innerHTML = `<div class="msg bot">สวัสดีครับ！我是您的清迈旅游助手。<br>可以问我关于人流密度、游客评价或推荐景点。${IC.building}</div>`;

  const steps = DEMO_SCENARIOS[query];
  for(const step of steps){
    await delay(700);
    if(step.type==='user'){
      body.innerHTML += `<div class="msg user">${step.text}</div>`;
    } else if(step.type==='tool'){
      const t = document.createElement('div');
      t.className='typing';
      t.innerHTML='<span></span><span></span><span></span>';
      body.appendChild(t);
      body.scrollTop = body.scrollHeight;
      await delay(800);
      t.remove();
      body.innerHTML += `<div class="tool-call">${IC.gear}${step.text}</div>`;
    } else {
      const t = document.createElement('div');
      t.className='typing';
      t.innerHTML='<span></span><span></span><span></span>';
      body.appendChild(t);
      body.scrollTop = body.scrollHeight;
      await delay(1200);
      t.remove();
      body.innerHTML += `<div class="msg bot">${step.text}</div>`;
    }
    body.scrollTop = body.scrollHeight;
  }
  chatRunning = false;
}

