  dot.addEventListener('click',()=>{
    document.getElementById(sections[i]).scrollIntoView({behavior:'smooth'});
  });
});
const secObs = new IntersectionObserver(entries=>{
  entries.forEach(e=>{
    if(e.isIntersecting){
      const idx = sections.indexOf(e.target.id);
      dots.forEach(d=>d.classList.remove('active'));
      if(idx>=0) dots[idx].classList.add('active');
      if(e.target.id==='metrics'){
        setTimeout(()=>{
          document.querySelectorAll('.hit-bar').forEach(b=>{ b.style.width=b.dataset.width; });
        },300);
      }
    }
  });
},{threshold:.4});
sections.forEach(id=>{ const el=document.getElementById(id); if(el) secObs.observe(el); });

