<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>智能体RAG · 智慧旅游 · 清迈</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Space+Mono:wght@400;700&family=Noto+Serif+Thai:wght@300;400;600&display=swap" rel="stylesheet">
<!-- Leaflet for interactive map -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<style>
:root{
  --ink:#0a0a0a;
  --paper:#f5f0e8;
  --gold:#c8972a;
  --gold2:#e8b84b;
  --saffron:#e07b39;
  --jade:#2d6a4f;
  --jade2:#40916c;
  --red:#c0392b;
  --smoke:#ede8de;
  --mist:#f9f6f0;
  --very-high:#c0392b;
  --high:#e07b39;
  --medium:#c8972a;
  --low:#2d6a4f;
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;scroll-snap-type:y mandatory;}
body{
  background:var(--paper);
  color:var(--ink);
  font-family:'Space Mono',monospace;
  overflow-x:hidden;
  cursor:none;
}

/* ── 自定义光标 ── */
#cursor{position:fixed;width:12px;height:12px;background:var(--gold);border-radius:50%;pointer-events:none;z-index:9999;transition:transform .15s ease,opacity .2s;mix-blend-mode:multiply;}
#cursor-ring{position:fixed;width:40px;height:40px;border:1.5px solid var(--gold);border-radius:50%;pointer-events:none;z-index:9998;transition:all .25s ease;mix-blend-mode:multiply;}

/* ── 滚动区块 ── */
section{
  min-height:100vh;
  scroll-snap-align:start;
  position:relative;
  display:flex;
  align-items:center;
  justify-content:center;
  overflow:hidden;
}

/* ══════════════════════════════════════════
   第0区 — 首屏
══════════════════════════════════════════ */
#hero{
  background:var(--ink);
  flex-direction:column;
  text-align:center;
}
.hero-noise{
  position:absolute;inset:0;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='4'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.06'/%3E%3C/svg%3E");
  pointer-events:none;opacity:.4;
}
.hero-grid{
  position:absolute;inset:0;
  background-image:
    linear-gradient(rgba(200,151,42,.07) 1px, transparent 1px),
    linear-gradient(90deg, rgba(200,151,42,.07) 1px, transparent 1px);
  background-size:60px 60px;
  animation:gridDrift 20s linear infinite;
}
@keyframes gridDrift{from{background-position:0 0;}to{background-position:60px 60px;}}

.hero-orb{
  position:absolute;
  border-radius:50%;
  filter:blur(80px);
  pointer-events:none;
  animation:orbFloat 8s ease-in-out infinite;
}
.orb1{width:500px;height:500px;background:radial-gradient(circle,rgba(200,151,42,.22),transparent 70%);top:-100px;right:-100px;}
.orb2{width:400px;height:400px;background:radial-gradient(circle,rgba(224,123,57,.18),transparent 70%);bottom:-80px;left:-80px;animation-delay:-4s;}
@keyframes orbFloat{0%,100%{transform:translate(0,0) scale(1);}50%{transform:translate(20px,-20px) scale(1.05);}}

.hero-inner{position:relative;z-index:2;padding:2rem;}
.hero-eyebrow{
  font-family:'Space Mono',monospace;
  font-size:.65rem;letter-spacing:.35em;
  color:var(--gold);text-transform:uppercase;
  margin-bottom:2rem;
  opacity:0;animation:fadeUp .8s .2s forwards;
}
.hero-title{
  font-family:'Playfair Display',serif;
  font-size:clamp(3rem,8vw,7rem);
  font-weight:900;
  color:#f5f0e8;
  line-height:.95;
  margin-bottom:1.5rem;
  opacity:0;animation:fadeUp .9s .4s forwards;
}
.hero-title em{
  display:block;
  font-style:italic;
  color:var(--gold);
  text-shadow:0 0 60px rgba(200,151,42,.4);
}
.hero-title span{
  display:block;
  font-size:clamp(1.2rem,3vw,2.4rem);
  font-weight:400;
  color:rgba(245,240,232,.5);
  letter-spacing:.05em;
  margin-top:.5rem;
}
.hero-sub{
  font-family:'Space Mono',monospace;
  font-size:.78rem;
  color:rgba(245,240,232,.45);
  letter-spacing:.1em;
  margin-bottom:3rem;
  opacity:0;animation:fadeUp .8s .6s forwards;
}
.hero-pills{
  display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;
  opacity:0;animation:fadeUp .8s .8s forwards;
}
.pill{
  padding:.5rem 1.2rem;
  border:1px solid rgba(200,151,42,.4);
  border-radius:100px;
  font-size:.65rem;
  letter-spacing:.15em;
  color:var(--gold2);
  text-transform:uppercase;
  backdrop-filter:blur(8px);
}
.hero-scroll{
  position:absolute;bottom:2rem;left:50%;transform:translateX(-50%);
  display:flex;flex-direction:column;align-items:center;gap:.5rem;
  opacity:0;animation:fadeUp .8s 1.2s forwards;
}
.hero-scroll span{font-size:.58rem;letter-spacing:.3em;color:rgba(245,240,232,.3);text-transform:uppercase;}
.scroll-line{width:1px;height:40px;background:linear-gradient(to bottom,var(--gold),transparent);animation:scrollPulse 2s ease-in-out infinite;}
@keyframes scrollPulse{0%,100%{opacity:.3;transform:scaleY(.8);}50%{opacity:1;transform:scaleY(1);}}
@keyframes fadeUp{from{opacity:0;transform:translateY(24px);}to{opacity:1;transform:translateY(0);}}

/* ══════════════════════════════════════════
   第1区 — 问题
══════════════════════════════════════════ */
#problem{
  background:var(--mist);
  flex-direction:column;
  padding:4rem 2rem;
}
.section-label{
  font-family:'Space Mono',monospace;
  font-size:.6rem;letter-spacing:.4em;
  text-transform:uppercase;
  color:var(--gold);
  margin-bottom:1.2rem;
}
.problem-layout{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:4rem;
  max-width:1100px;
  width:100%;
  align-items:center;
}
@media(max-width:768px){.problem-layout{grid-template-columns:1fr;gap:2rem;}}
.problem-text h2{
  font-family:'Playfair Display',serif;
  font-size:clamp(2rem,4vw,3.5rem);
  font-weight:900;
  line-height:1.1;
  margin-bottom:1.5rem;
  color:var(--ink);
}
.problem-text h2 em{font-style:italic;color:var(--saffron);}
.problem-text p{
  font-size:.82rem;line-height:1.9;
  color:#444;margin-bottom:1rem;
}
.stat-stack{display:flex;flex-direction:column;gap:1.2rem;}
.stat-card{
  background:white;
  border-radius:16px;
  padding:1.5rem 2rem;
  border-left:4px solid;
  box-shadow:0 4px 24px rgba(0,0,0,.06);
  transition:transform .3s ease,box-shadow .3s ease;
  cursor:default;
}
.stat-card:hover{transform:translateX(8px);box-shadow:0 8px 40px rgba(0,0,0,.12);}
.stat-card.very-high{border-color:var(--very-high);}
.stat-card.high{border-color:var(--high);}
.stat-card.medium{border-color:var(--medium);}
.stat-card.low{border-color:var(--jade);}
.stat-card .num{
  font-size:2.5rem;font-weight:700;
  font-family:'Playfair Display',serif;
  line-height:1;
}
.stat-card.very-high .num{color:var(--very-high);}
.stat-card.high .num{color:var(--high);}
.stat-card.medium .num{color:var(--medium);}
.stat-card.low .num{color:var(--jade);}
.stat-card .label{font-size:.65rem;letter-spacing:.15em;text-transform:uppercase;color:#888;margin-top:.3rem;}
.stat-card .desc{font-size:.75rem;color:#555;margin-top:.5rem;line-height:1.6;}

/* ══════════════════════════════════════════
   第2区 — 系统流程
══════════════════════════════════════════ */
#pipeline{
  background:var(--ink);
  flex-direction:column;
  padding:4rem 2rem;
}
#pipeline .section-label{color:var(--gold);}
#pipeline h2{
  font-family:'Playfair Display',serif;
  font-size:clamp(2rem,4vw,3rem);
  color:#f5f0e8;
  font-weight:900;
  text-align:center;
  margin-bottom:.5rem;
}
#pipeline .sub{
  text-align:center;font-size:.75rem;
  color:rgba(245,240,232,.4);letter-spacing:.08em;
  margin-bottom:3rem;
}
.pipeline-flow{
  display:flex;
  align-items:stretch;
  gap:0;
  max-width:1100px;
  width:100%;
  flex-wrap:wrap;
  justify-content:center;
}
.pipe-step{
  flex:1;min-width:160px;max-width:220px;
  position:relative;
  padding:2rem 1.5rem 2rem;
  text-align:center;
  cursor:pointer;
  transition:transform .3s ease;
}
.pipe-step:hover{transform:translateY(-8px);}
.pipe-step::after{
  content:'→';
  position:absolute;right:-12px;top:50%;transform:translateY(-50%);
  color:var(--gold);font-size:1.2rem;
  z-index:2;
}
.pipe-step:last-child::after{display:none;}
.pipe-icon{
  width:64px;height:64px;
  background:rgba(200,151,42,.12);
  border:1.5px solid rgba(200,151,42,.3);
  border-radius:16px;
  display:flex;align-items:center;justify-content:center;
  font-size:1.8rem;margin:0 auto 1rem;
  transition:all .3s ease;
  color:var(--gold);
}
.pipe-icon svg{width:32px;height:32px;fill:none;stroke:currentColor;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round;}
.pipe-step:hover .pipe-icon{
  background:rgba(200,151,42,.25);
  border-color:var(--gold);
  box-shadow:0 0 30px rgba(200,151,42,.3);
}
.icon{display:inline-flex;align-items:center;vertical-align:middle;line-height:1;}
.icon svg{fill:none;stroke:currentColor;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;}
.pipe-step h3{
  font-family:'Playfair Display',serif;
  font-size:1rem;color:#f5f0e8;
  margin-bottom:.5rem;font-style:italic;
}
.pipe-step p{font-size:.65rem;color:rgba(245,240,232,.45);line-height:1.7;}
.pipe-tag{
  display:inline-block;
  margin-top:.8rem;
  padding:.25rem .7rem;
  border-radius:100px;
  font-size:.55rem;
  letter-spacing:.12em;
  text-transform:uppercase;
  background:rgba(200,151,42,.15);
  color:var(--gold2);
  border:1px solid rgba(200,151,42,.2);
}
.pipe-step.active-step .pipe-icon{
  background:var(--gold);
  border-color:var(--gold);
  animation:pipePulse 2s ease-in-out infinite;
  color:white;
}
@keyframes pipePulse{0%,100%{box-shadow:0 0 0 0 rgba(200,151,42,.4);}50%{box-shadow:0 0 0 16px rgba(200,151,42,0);}}

/* ══════════════════════════════════════════
   第3区 — POI 热力密度
══════════════════════════════════════════ */
#density{
  background:var(--smoke);
  flex-direction:column;
  padding:4rem 2rem;
}
#density h2{
  font-family:'Playfair Display',serif;
  font-size:clamp(2rem,4vw,3rem);
  font-weight:900;
  text-align:center;
  margin-bottom:.5rem;
}
#density h2 em{font-style:italic;color:var(--saffron);}
#density .sub{
  text-align:center;font-size:.75rem;
  color:#888;letter-spacing:.08em;margin-bottom:2.5rem;
}
.filter-row{
  display:flex;gap:.6rem;flex-wrap:wrap;
  justify-content:center;margin-bottom:2rem;
}
.filter-btn{
  padding:.4rem 1rem;
  border-radius:100px;
  border:1.5px solid;
  font-size:.62rem;
  letter-spacing:.1em;
  text-transform:uppercase;
  cursor:pointer;
  transition:all .25s ease;
  font-family:'Space Mono',monospace;
  background:transparent;
}
.filter-btn.all{border-color:var(--ink);color:var(--ink);}
.filter-btn.all.active,.filter-btn.all:hover{background:var(--ink);color:white;}
.filter-btn.very_high{border-color:var(--very-high);color:var(--very-high);}
.filter-btn.very_high.active,.filter-btn.very_high:hover{background:var(--very-high);color:white;}
.filter-btn.high{border-color:var(--high);color:var(--high);}
.filter-btn.high.active,.filter-btn.high:hover{background:var(--high);color:white;}
.filter-btn.medium{border-color:var(--medium);color:var(--medium);}
.filter-btn.medium.active,.filter-btn.medium:hover{background:var(--medium);color:white;}
.filter-btn.low{border-color:var(--jade);color:var(--jade);}
.filter-btn.low.active,.filter-btn.low:hover{background:var(--jade);color:white;}

.poi-grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(260px,1fr));
  gap:1rem;
  max-width:1100px;
  width:100%;
  max-height:520px;
  overflow-y:auto;
  padding-right:.5rem;
}
.poi-grid::-webkit-scrollbar{width:4px;}
.poi-grid::-webkit-scrollbar-track{background:transparent;}
.poi-grid::-webkit-scrollbar-thumb{background:var(--gold);border-radius:2px;}

.poi-card{
  background:white;
  border-radius:16px;
  padding:1.4rem;
  cursor:pointer;
  transition:all .3s ease;
  border:1.5px solid transparent;
  position:relative;
  overflow:hidden;
}
.poi-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:3px;
}
.poi-card.very_high::before{background:var(--very-high);}
.poi-card.high::before{background:var(--high);}
.poi-card.medium::before{background:var(--medium);}
.poi-card.low::before{background:var(--jade);}
.poi-card:hover{
  transform:translateY(-4px);
  box-shadow:0 16px 48px rgba(0,0,0,.12);
  border-color:rgba(200,151,42,.3);
}
.poi-card-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:.8rem;}
.poi-name{
  font-family:'Playfair Display',serif;
  font-size:1rem;font-weight:700;
  line-height:1.2;flex:1;
}
.risk-badge{
  padding:.2rem .6rem;
  border-radius:100px;
  font-size:.55rem;
  letter-spacing:.1em;
  text-transform:uppercase;
  font-weight:700;
  white-space:nowrap;
  margin-left:.5rem;
}
.risk-badge.very_high{background:#fde8e6;color:var(--very-high);}
.risk-badge.high{background:#fdf0e6;color:var(--high);}
.risk-badge.medium{background:#fdf8e6;color:#a07820;}
.risk-badge.low{background:#e8f5ee;color:var(--jade);}
.poi-category{font-size:.6rem;color:#999;letter-spacing:.1em;text-transform:uppercase;margin-bottom:.8rem;}
.density-bar-wrap{margin-bottom:.6rem;}
.density-label{display:flex;justify-content:space-between;font-size:.62rem;margin-bottom:.3rem;}
.density-label span:first-child{color:#666;}
.density-label span:last-child{font-weight:700;}
.density-bar{height:6px;background:#eee;border-radius:3px;overflow:hidden;}
.density-fill{height:100%;border-radius:3px;transition:width 1s ease;position:relative;}
.density-fill::after{
  content:'';position:absolute;top:0;right:0;bottom:0;width:30%;
  background:linear-gradient(to right,transparent,rgba(255,255,255,.4));
}
.poi-card.very_high .density-fill{background:linear-gradient(90deg,var(--very-high),#e74c3c);}
.poi-card.high .density-fill{background:linear-gradient(90deg,var(--high),var(--saffron));}
.poi-card.medium .density-fill{background:linear-gradient(90deg,var(--medium),var(--gold2));}
.poi-card.low .density-fill{background:linear-gradient(90deg,var(--jade),var(--jade2));}
.poi-meta{display:flex;gap:.8rem;font-size:.62rem;color:#888;}
.poi-meta span{display:flex;align-items:center;gap:.3rem;}

/* ══════════════════════════════════════════
   第3.5区 — 交互地图（新增）
══════════════════════════════════════════ */
#map-section{
  background:var(--paper);
  flex-direction:column;
  padding:4rem 2rem;
}
#map-section h2{
  font-family:'Playfair Display',serif;
  font-size:clamp(2rem,4vw,3rem);
  font-weight:900;
  text-align:center;
  margin-bottom:.5rem;
}
#map-section h2 em{font-style:italic;color:var(--saffron);}
#map-section .sub{
  text-align:center;font-size:.75rem;
  color:#888;letter-spacing:.08em;margin-bottom:2.5rem;
}
.map-layout{
  display:grid;
  grid-template-columns:1fr 340px;
  gap:2rem;
  max-width:1200px;
  width:100%;
  align-items:start;
}
@media(max-width:900px){
  .map-layout{grid-template-columns:1fr;}
}
#poi-map{
  width:100%;
  height:500px;
  border-radius:24px;
  box-shadow:0 20px 40px rgba(0,0,0,.1);
  border:1px solid rgba(200,151,42,.2);
  overflow:hidden;
  z-index:1;
}
.map-sidebar{
  display:flex;
  flex-direction:column;
  gap:1rem;
}
.map-legend{
  background:white;
  border-radius:20px;
  padding:1.5rem;
  box-shadow:0 4px 20px rgba(0,0,0,.06);
}
.map-legend-title{
  font-size:.7rem;
  font-weight:700;
  letter-spacing:.15em;
  text-transform:uppercase;
  color:var(--gold);
  margin-bottom:1rem;
}
.legend-row{
  display:flex;
  align-items:center;
  gap:10px;
  font-size:.75rem;
  color:#555;
  margin-bottom:10px;
}
.legend-dot-circle{
  width:14px;
  height:14px;
  border-radius:50%;
  flex-shrink:0;
}
.map-poi-list{
  background:white;
  border-radius:20px;
  box-shadow:0 4px 20px rgba(0,0,0,.06);
  overflow:hidden;
}
.map-poi-list-header{
  padding:1rem 1.2rem;
  background:var(--gold);
  color:white;
  font-size:.7rem;
  font-weight:700;
  letter-spacing:.1em;
  text-transform:uppercase;
}
.map-poi-row{
  display:flex;
  align-items:center;
  gap:12px;
  padding:12px 16px;
  border-bottom:1px solid #eee;
  cursor:pointer;
  transition:all .2s ease;
}
.map-poi-row:hover{
  background:rgba(200,151,42,.08);
}
.map-poi-row:last-child{border-bottom:none;}
.poi-dot{
  width:10px;
  height:10px;
  border-radius:50%;
  flex-shrink:0;
}
.poi-name-th{
  font-size:.8rem;
  font-weight:700;
  color:var(--ink);
}
.poi-name-en{
  font-size:.65rem;
  color:#999;
}
.poi-density{
  font-size:.8rem;
  font-weight:800;
  color:var(--gold);
  margin-left:auto;
}
.map-time-badge{
  background:white;
  border-radius:20px;
  padding:1rem 1.2rem;
  box-shadow:0 4px 20px rgba(0,0,0,.06);
  font-size:.7rem;
  color:#666;
  line-height:1.6;
}
.map-time-badge strong{color:var(--saffron);}
.poi-preview-section{
  margin-top:2rem;
  border-top:1px solid rgba(0,0,0,.08);
  padding-top:1.5rem;
  display:none;
}
.poi-preview-section.active{display:block;}
.poi-preview-eyebrow{
  display:inline-flex;
  align-items:center;
  gap:6px;
  font-size:.6rem;
  font-weight:700;
  letter-spacing:.12em;
  text-transform:uppercase;
  color:var(--gold);
  margin-bottom:.5rem;
}
.poi-preview-eyebrow::before{
  content:'';
  width:16px;
  height:2px;
  background:var(--gold);
  border-radius:2px;
}
.poi-preview-title{
  font-size:1rem;
  font-weight:800;
  color:var(--ink);
}
.poi-preview-title-en{
  font-size:.7rem;
  color:#888;
  margin-bottom:.8rem;
}
.poi-preview-grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:12px;
}
.poi-preview-img-wrap{
  border-radius:16px;
  overflow:hidden;
  aspect-ratio:16/10;
  background:#ddd;
  box-shadow:0 4px 12px rgba(0,0,0,.08);
  transition:transform .3s ease;
}
.poi-preview-img-wrap:hover{transform:translateY(-4px);}
.poi-preview-img-wrap img{
  width:100%;
  height:100%;
  object-fit:cover;
  display:block;
}
.poi-preview-img-label{
  display:none;
}
@media(max-width:600px){
  .poi-preview-grid{grid-template-columns:1fr;}
}
.leaflet-popup-content-wrapper{
  border-radius:16px !important;
  box-shadow:0 8px 32px rgba(0,0,0,.15) !important;
}
.leaflet-popup-tip{display:none;}
.poi-popup{padding:12px 16px;min-width:200px;}
.poi-popup-name{font-size:.9rem;font-weight:800;color:var(--ink);margin-bottom:2px;}
.poi-popup-en{font-size:.7rem;color:#888;margin-bottom:10px;}
.poi-popup-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
.poi-popup-stat{background:#f5f0e8;border-radius:12px;padding:8px 10px;text-align:center;}
.poi-popup-val{font-size:1rem;font-weight:800;color:var(--ink);}
